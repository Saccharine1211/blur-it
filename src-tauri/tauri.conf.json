{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlurIt",
  "version": "0.1.0",
  "identifier": "com.blurit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "BlurIt",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 600,
        "minHeight": 450
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "fileAssociations": [
      {
        "ext": ["png", "jpg", "jpeg", "bmp", "webp"],
        "mimeType": "image/*",
        "description": "Image files"
      }
    ]
  }
}
